# ==========================================================
#  AI Business Enterprise - Environment Variables Template
#  इस फाइल को कॉपी करके ".env" नाम से सेव करें और values भरें
#  cp .env.example .env   (Windows: copy .env.example .env)
# ==========================================================

# --- Supabase ---
# Supabase Dashboard -> Project Settings -> API से लें
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# --- Groq (LLM provider) ---
# https://console.groq.com/keys से API key लें
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Orchestrator settings ---
# हर कितने सेकंड में नए tasks check करने हैं
ORCHESTRATOR_POLL_INTERVAL=10
# एक साथ कितने tasks process करें
ORCHESTRATOR_BATCH_SIZE=5

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Website (Aitotech) integration ---
# Production में सिर्फ अपनी website का domain डालें (comma-separated multiple)
# जैसे: https://aitotech.com,https://www.aitotech.com
# Dev में "*" से सब allow होता है।
WEBSITE_ALLOWED_ORIGINS=*

# --- Dashboard (Next.js) के लिए (dashboard/.env.local में डालें) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# NEXT_PUBLIC_API_URL=http://localhost:8000
